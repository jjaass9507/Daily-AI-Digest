# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# GitHub Personal Access Token (public_repo read is enough)
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# Anthropic API Key
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# NeonDB connection string
# https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Number of repos to include in each daily digest (default: 8)
DIGEST_SIZE=8

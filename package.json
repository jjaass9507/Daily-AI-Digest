{
  "name": "daily-ai-digest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "rm -rf node_modules/puppeteer node_modules/puppeteer-core 2>/dev/null; exit 0",
    "start": "node server.mjs",
    "update:digest": "node scripts/update-digest.mjs",
    "db:schema": "node scripts/apply-schema.mjs",
    "setup:digest": "node scripts/apply-schema.mjs && node scripts/update-digest.mjs",
    "agent:digest": "node scripts/agent-digest.mjs"
  },
  "dependencies": {
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1"
  },
  "engines": {
    "node": ">=20"
  }
}
